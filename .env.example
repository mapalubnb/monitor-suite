# ══════════════════════════════════════════
# Monitor Suite 环境变量配置
# 复制此文件为 .env 并填入真实值
# ══════════════════════════════════════════

# ── 飞书应用凭证（唯一通讯通道） ──
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here

# ── 飞书群 Chat ID（所有消息发送到此群） ──
FEISHU_CHAT_ID=oc_xxxxxxxxxxxx

# ── 飞书 Bot 安全（open_id 白名单，逗号分隔，留空则不限制） ──
FEISHU_ALLOWED_SENDERS=

# ── AI 模型 API Key（至少配置一个即可使用 AI 摘要功能） ──
DOUBAO_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
GLM_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=

# ── GitHub（可选，提升 API rate limit 至 5000/h） ──
GITHUB_TOKEN=

# ── Four.meme 链上创建者动作监听（可选） ──
# Etherscan API V2 key；仅作为备用查询，BSC 使用 chainid=56，可能需要 paid tier。
ETHERSCAN_V2_API_KEY=
ETHERSCAN_API_KEY=
# 旧变量名兼容；优先级低于 ETHERSCAN_V2_API_KEY / ETHERSCAN_API_KEY。
BSCSCAN_API_KEY=
# 手动补充需要重点监听的钱包地址，多个用逗号分隔；通常不需要。
FOURMEME_WATCH_ACTORS=
FOURMEME_WATCH_CREATORS=
# 默认开启；设为 false 可关闭模块8。
FOURMEME_ACTOR_MONITOR=true
# 默认自动从 BscScan 合约地址页读取 Contract Creator/deployer 并缓存。
BSCSCAN_WEB_BASE=https://bscscan.com
FOURMEME_CREATOR_PAGE_LOOKUP=true
FOURMEME_CREATOR_PAGE_MAX_PER_RUN=8
FOURMEME_CREATOR_LOOKUP_COOLDOWN_MINUTES=30
# 页面抓取被封时，用 BSC RPC 在近期区块中反查新合约创建交易作为兜底。
FOURMEME_CREATOR_CHAIN_LOOKUP=true
FOURMEME_CREATOR_CHAIN_LOOKBACK_BLOCKS=30000
FOURMEME_CREATOR_CHAIN_MAX_BLOCKS_PER_RUN=120
# Etherscan V2 API 备用查询；页面抓取被封且 API key 支持 BSC getcontractcreation 时再开启。
FOURMEME_CREATOR_LOOKUP=false
# 默认 2 个确认块，首次启动默认回看最近 6 个确认块。
FOURMEME_ACTOR_CONFIRMATIONS=2
FOURMEME_ACTOR_BOOTSTRAP_BLOCKS=6
FOURMEME_ACTOR_MAX_BLOCKS=8

# ── 运行参数 ──
# 心跳推送间隔（分钟），默认 240（4 小时）
HEARTBEAT_MINUTES=240
# 是否开启每日报告，true/false
DAILY_REPORT=false
# 日报发送时间（0-23，北京时间），默认 9 点
DAILY_REPORT_HOUR=9

# ══════════════════════════════════════════
# Monitor Suite 环境变量配置
# 复制此文件为 .env 并填入真实值
# ══════════════════════════════════════════

# ── 飞书应用凭证 ──
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here

# ── 飞书 Webhook（fourmeme 群）──
FEISHU_WEBHOOK_FOURMEME=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id
FEISHU_SECRET_FOURMEME=your_webhook_secret

# ── 飞书 Webhook（flap 群）──
FEISHU_WEBHOOK_FLAP=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id
FEISHU_SECRET_FLAP=your_webhook_secret

# ── 飞书群 Chat ID ──
FEISHU_CHAT_ID=oc_xxxxxxxxxxxx

# ── 飞书 Bot 安全 ──
FEISHU_ALLOWED_SENDERS=

# ── AI 模型 API Key ──
DOUBAO_API_KEY=your_doubao_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
QWEN_API_KEY=
GLM_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=

# ── GitHub（可选，提升 rate limit）──
GITHUB_TOKEN=

# ── 运行参数 ──
HEARTBEAT_MINUTES=240
DAILY_REPORT=false
DAILY_REPORT_HOUR=9

# ══════════════════════════════════════════
# Monitor Suite 环境变量配置
# 复制此文件为 .env 并填入真实值
# ══════════════════════════════════════════

# ── 飞书应用凭证（唯一通讯通道） ──
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here

# ── 飞书群 Chat ID（所有消息发送到此群） ──
FEISHU_CHAT_ID=oc_xxxxxxxxxxxx

# ── 飞书 Bot 安全（open_id 白名单，逗号分隔，留空则不限制） ──
FEISHU_ALLOWED_SENDERS=

# ── 飞书输出控制（可选；超长内容会分多条/多张卡片发送，不截断） ──
FEISHU_TEXT_CHUNK_LIMIT=3500
FEISHU_CARD_CHUNK_LIMIT=3500
FEISHU_BOT_EXEC_MAX_BUFFER=16777216

# ── AI 模型 API Key（至少配置一个即可使用 AI 摘要功能） ──
DOUBAO_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
GLM_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=

# ── Four.meme 前端/API 频率与并发 ──
# 前端页面池监控间隔，默认/最低 10 秒；API 结构和值监控间隔，默认/最低 15 秒。
FOURMEME_FRONTEND_INTERVAL_SECONDS=10
FOURMEME_API_INTERVAL_SECONDS=15
# 稳定状态尽量贴近目标频率；调度抖动默认 200ms，设 0 可关闭。
FOURMEME_MODULE_JITTER_MS=200
# 前端抓取并发，默认 6/6；被风控时建议降到 4/4。
FOURMEME_FRONTEND_HTML_CONCURRENCY=6
FOURMEME_FRONTEND_ASSET_CONCURRENCY=6
# API 探针内部错峰，默认 200ms；不建议设 0，避免同域瞬时并发过高。
FOURMEME_API_PROBE_STAGGER_MS=200
# 新发现前端页面 warm-up 稳定轮数，默认 1；设 2 可降低 SSR 抖动误报。
FOURMEME_FRONTEND_WARMUP_STABLE_RUNS=1

# ── Four.meme Cloudflare 抓取方案 ──
# 默认使用服务器本机 Scrapling stealth 浏览器 sidecar，不依赖本地手动验证 Chrome profile。
FOURMEME_FRONTEND_FETCH_PROVIDER=scrapling
FOURMEME_SCRAPLING_FETCH_ENABLED=true
FOURMEME_SCRAPLING_FETCH_URL=http://127.0.0.1:8787/fetch
FOURMEME_SCRAPLING_TIMEOUT_MS=80000
FOURMEME_SCRAPLING_MIN_INTERVAL_MS=250
FOURMEME_SCRAPLING_MAX_HTML_BYTES=8000000
FOURMEME_API_SCRAPLING_FALLBACK_ENABLED=true
FOURMEME_API_SCRAPLING_TIMEOUT_MS=30000
FOURMEME_API_SCRAPLING_MAX_TEXT_BYTES=4000000
FOURMEME_API_DIRECT_RETRY_SECONDS=300
FOURMEME_SCRAPLING_HOST=127.0.0.1
FOURMEME_SCRAPLING_PORT=8787
FOURMEME_SCRAPLING_MAX_PAGES=4
FOURMEME_SCRAPLING_PAGE_TIMEOUT_MS=60000
FOURMEME_SCRAPLING_FETCH_TOTAL_TIMEOUT_MS=65000
FOURMEME_SCRAPLING_FETCH_WITH_ASSETS_TOTAL_TIMEOUT_MS=75000
FOURMEME_SCRAPLING_MAX_TEXT_BYTES=4000000
FOURMEME_SCRAPLING_WAIT_MS=0
FOURMEME_SCRAPLING_WARMUP_URL=https://four.meme/en
FOURMEME_SCRAPLING_WARMUP_TIMEOUT_MS=90000
FOURMEME_SCRAPLING_ALLOWED_HOSTS=four.meme,*.four.meme
# 仅当 sidecar 绑定非 localhost 或经过反代暴露时必须设置；Node 会通过同名变量发送鉴权头。
FOURMEME_SCRAPLING_TOKEN=
FOURMEME_SCRAPLING_HEADLESS=true
FOURMEME_SCRAPLING_SOLVE_CLOUDFLARE=true
FOURMEME_SCRAPLING_WAIT_NETWORK_IDLE=false
FOURMEME_SCRAPLING_DISABLE_RESOURCES=false
FOURMEME_SCRAPLING_MAX_ASSETS=20
FOURMEME_SCRAPLING_MAX_ASSET_BYTES=1000000
FOURMEME_SCRAPLING_MAX_ASSET_TOTAL_BYTES=6000000
FOURMEME_SCRAPLING_ASSET_TIMEOUT_MS=8000
FOURMEME_SCRAPLING_ASSET_TOTAL_TIMEOUT_MS=15000
FOURMEME_SCRAPLING_ASSET_CONCURRENCY=4
# 可选：当服务器出口 IP 被 Cloudflare 高强度拦截时，填入住宅/ISP 代理。
FOURMEME_SCRAPLING_PROXY=

# 可选兼容模式：仅在 FOURMEME_FRONTEND_FETCH_PROVIDER=browser_session 时使用。
FOURMEME_FRONTEND_BROWSER_FETCH_ENABLED=false
FOURMEME_FRONTEND_BROWSER_FETCH_FORCED=false
FOURMEME_FRONTEND_BROWSER_FETCH_COMMAND=node
FOURMEME_FRONTEND_BROWSER_FETCH_ARGS=fourmeme-monitor/browser-session-fetch.mjs
FOURMEME_FRONTEND_BROWSER_FETCH_TIMEOUT_MS=20000
FOURMEME_FRONTEND_BROWSER_FETCH_MIN_INTERVAL_MS=1000
FOURMEME_BROWSER_CDP_URL=http://127.0.0.1:9222
FOURMEME_BROWSER_FETCH_WAIT_MS=3500
# 主监控会按需覆盖这个值：10s 常规轮询只取 HTML，资源列表变化时再取 JS/CSS。
FOURMEME_BROWSER_FETCH_ASSETS=false
FOURMEME_BROWSER_FETCH_MAX_ASSETS=80
FOURMEME_BROWSER_FETCH_MAX_ASSET_BYTES=1000000

# ── OpenFour 业务模板监控 ──
# 监控 /v1/public/token_template/search 的新模板上线和 status 变化，默认/最低 3 秒。
OPENFOUR_TEMPLATE_INTERVAL_SECONDS=3
# 监听 OpenFourRegistry 链上 logs，触发新 module/token implementation 地址发现。
OPENFOUR_REGISTRY_LOG_MONITOR=true
OPENFOUR_REGISTRY_DISCOVERY_DEBOUNCE_MS=3000

# ── GitHub（可选，提升 API rate limit 至 5000/h） ──
GITHUB_TOKEN=
# 主仓库提交监控间隔：有 GITHUB_TOKEN 默认/最低 30 秒；无 token 默认/最低 90 秒。
GITHUB_INTERVAL_SECONDS=
# 账号仓库列表监控间隔：默认/最低 300 秒。提交监控不受这个间隔影响。
GITHUB_REPO_LIST_INTERVAL_SECONDS=300

# ── Four.meme 链上创建者动作监听（可选） ──
# Etherscan API V2 key；仅作为备用查询，BSC 使用 chainid=56，可能需要 paid tier。
ETHERSCAN_V2_API_KEY=
ETHERSCAN_API_KEY=
# 旧变量名兼容；优先级低于 ETHERSCAN_V2_API_KEY / ETHERSCAN_API_KEY。
BSCSCAN_API_KEY=
# 手动补充需要重点监听的钱包地址，多个用逗号分隔；通常不需要。
FOURMEME_WATCH_ACTORS=
FOURMEME_WATCH_CREATORS=
# 默认开启；设为 false 可关闭模块8。
FOURMEME_ACTOR_MONITOR=true
# 默认自动从 BscScan 合约地址页读取 Contract Creator/deployer 并缓存。
BSCSCAN_WEB_BASE=https://bscscan.com
FOURMEME_CREATOR_PAGE_LOOKUP=true
FOURMEME_CREATOR_PAGE_MAX_PER_RUN=2
FOURMEME_CREATOR_LOOKUP_COOLDOWN_MINUTES=30
# 页面抓取被封时，用 BSC RPC 在近期区块中反查新合约创建交易作为兜底。
FOURMEME_CREATOR_CHAIN_LOOKUP=true
FOURMEME_CREATOR_CHAIN_LOOKBACK_BLOCKS=30000
FOURMEME_CREATOR_CHAIN_MAX_BLOCKS_PER_RUN=120
# Etherscan V2 API 备用查询；页面抓取被封且 API key 支持 BSC getcontractcreation 时再开启。
FOURMEME_CREATOR_LOOKUP=false
# 创建者动作扫链：默认启用 WebSocket 新区块订阅；HTTP 扫描仍作为断线/漏事件兜底。
BSC_WS_URLS=wss://bsc-rpc.publicnode.com
FOURMEME_ACTOR_WS_ENABLED=true
FOURMEME_ACTOR_HTTP_FALLBACK_MS=10000
# 默认 1 个确认块；每批 80 块，落后时同轮最多追 800 块。
FOURMEME_ACTOR_CONFIRMATIONS=1
FOURMEME_ACTOR_BOOTSTRAP_BLOCKS=20
FOURMEME_ACTOR_MAX_BLOCKS=80
FOURMEME_ACTOR_CATCHUP_MAX_BLOCKS=800
FOURMEME_ACTOR_MAX_RUN_MS=45000
FOURMEME_ACTOR_LAG_WARN_BLOCKS=120
FOURMEME_ACTOR_CATCHUP_LOG_MINUTES=5
FOURMEME_ACTOR_CATCHUP_LOG_DELTA_BLOCKS=5000

# ── 运行参数 ──
# 心跳推送开关，默认关闭；设为 true 可恢复周期性状态心跳
HEARTBEAT_ENABLED=false
# 心跳推送间隔（分钟），默认 240（4 小时）
HEARTBEAT_MINUTES=240
# 是否开启每日报告，true/false
DAILY_REPORT=false
# 日报发送时间（0-23，北京时间），默认 9 点
DAILY_REPORT_HOUR=9
